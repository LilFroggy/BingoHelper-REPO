{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Guide Schema",
    "description": "The schema that is used to validate guides.",
    "type": "object",
    "properties": {
        "name": { "type": "string" },
        "version": { "type": "integer" },
        "data": { "type": "object",
            "properties": {
                "stepIndex": { "type": "integer" },
                "steps": { "type": "array",
                    "items": { "type": "object",
                        "properties": {
                            "type": { "$ref": "#/definitions/StepTypes" },
                            "instruction": { "type": "string" },
                            "command": { "type": "string" },
                            "waypoint": { "$ref": "#/definitions/WaypointProperty" },
                            "outlineEntity": { "$ref": "#/definitions/OutlineEntityProperty" },
							"async": { "$ref": "#/definitions/AsyncProperty" },
                            "ranks": { "type": "array",
                                "items": { "type": "integer" },
                                "minItems": 1
                            }
                        },
                        "oneOf": [
                            { "$ref": "#/definitions/MessageStep" },
                            { "$ref": "#/definitions/CakeStep" },
                            { "$ref": "#/definitions/SellStep" },
                            { "$ref": "#/definitions/BuyStep" },
                            { "$ref": "#/definitions/HasStep" },
                            { "$ref": "#/definitions/AreaStep" },
                            { "$ref": "#/definitions/SubAreaStep" },
                            { "$ref": "#/definitions/EnchantStep" },
                            { "$ref": "#/definitions/ReforgeStep" },
                            { "$ref": "#/definitions/GuiItemStep" },
                            { "$ref": "#/definitions/ClickSlotStep" },
                            { "$ref": "#/definitions/SkillStep" },
                            { "$ref": "#/definitions/CollectionStep" },
                            { "$ref": "#/definitions/StoreStep" },
                            { "$ref": "#/definitions/RetrieveStep" },
                            { "$ref": "#/definitions/ExperienceStep" },
                            { "$ref": "#/definitions/UpgradeMinionStep" },
							{ "$ref": "#/definitions/MobTypesStep" }
                        ],
                        "required": [
                            "type",
                            "instruction"
                        ]
                    },
					"additionalProperties": false
                }
            },
            "required": [
                "stepIndex",
                "steps"
            ]
        },
		"additionalProperties": false
    },
    "required": [
        "name",
        "version",
        "data"
    ],
    "definitions": {
        "WaypointProperty": { "type": "object",
            "properties": {
                "type": { "const": "list" },
                "beam": { "type": "boolean" },
                "list": { "type": "array",
                    "items": { "type": "object",
                        "properties": {
                            "text": { "type": "string" },
                            "position": { "type": "array",
                                "items": { "type": "number" },
                                "minItems": 3,
                                "maxItems": 3
                            },
                            "radius": { "type": "integer" }
                        },
						"additionalProperties": false,
                        "required": [
                            "text",
                            "position",
                            "radius"
                        ]
                    }
                },
                "index": { "type": "integer" }
            },
			"additionalProperties": false,
            "required": [
                "type",
                "beam",
                "list",
                "index"
            ]
        },
        "OutlineEntityProperty": { "type": "object",
            "$ref": "#/definitions/EntityPredicate"
        },
		"AsyncProperty": { "type": "object",
            "properties": {
                "effectiveIndex": { "type": "integer" },
				"requirements": { "type": "object",
					"properties": {
						"entity": { "$ref": "#/definitions/EntityPredicate" }
					},
					"additionalProperties": false,
					"minProperties": 1
				}
            },
			"additionalProperties": false
        },
		"EntityPredicate": { "type": "object",
			"properties": {
                "type": { "type": "string" },
                "position": { "type": "array",
                    "items": { "type": "number" },
                    "minItems": 3,
                    "maxItems": 3
                },
				"skin": { "type": "string" }
            },
			"additionalProperties": false,
			"minProperties": 1
		},
        "StepTypes": {
            "enum": [
                "message",
                "cake",
                "sell",
                "buy",
                "has",
                "area",
                "subArea",
                "enchant",
                "reforge",
                "guiItem",
                "clickSlot",
                "skill",
                "collection",
                "store",
                "retrieve",
                "experience",
                "upgradeMinion",
				"mobTypes"
            ]
        },
        "MessageStep": { "type": "object",
            "properties": {
                "type": { "const": "message" },
                "criteria": { "type": "string" }
            },
            "required": [
                "criteria"
            ]
        },
        "CakeStep": { "type": "object",
            "properties": {
                "type": { "const": "cake" },
                "eaten": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            },
            "required": [
                "eaten"
            ]
        },
        "SellStep": { "type": "object",
            "properties": {
                "type": { "const": "sell" },
                "items": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/ItemIds" }
                }
            },
            "required": [
                "items"
            ]
        },
        "BuyStep": { "type": "object",
            "properties": {
                "type": { "const": "buy" },
                "items": { "type": "object",
                    "propertyNames": {
                        "$ref": "#/definitions/ItemIds"
                    },
					"additionalProperties": {
                        "type": "object",
                        "properties": {
                            "count": { "type": "integer" },
                            "target": { "type": "integer" },
                            "done": { "type": "boolean" }
                        },
                        "required": [
                            "count",
                            "target",
                            "done"
                        ]
                    }
                }
            },
            "required": [
                "items"
            ]
        },
        "HasStep": { "type": "object",
            "properties": {
                "type": { "const": "has" },
                "items": { "type": "object",
                "propertyNames": {
                        "$ref": "#/definitions/ItemIds"
                    },
					"additionalProperties": {
                        "type": "object",
                        "properties": {
                            "count": { "type": "integer" },
                            "target": { "type": "integer" },
                            "done": { "type": "boolean" }
                        },
                        "required": [
                            "count",
                            "target",
                            "done"
                        ]
                    }
                }
            },
            "required": [
                "items"
            ]
        },
        "AreaStep": { "type": "object",
            "properties": {
                "type": { "const": "area" },
                "area": { "$ref": "#/definitions/Area" }
            },
            "required": [
                "area"
            ]
        },
        "SubAreaStep": { "type": "object",
            "properties": {
                "type": { "const": "subArea" },
                "subArea": { "$ref": "#/definitions/SubArea" }
            },
            "required": [
                "subArea"
            ]
        },
        "EnchantStep": { "type": "object",
            "properties": {
                "type": { "const": "enchant" },
                "items": { "type": "object",
                    "propertyNames": {
                        "$ref": "#/definitions/ItemIds"
                    },
					"additionalProperties": { "type": "object",
                        "properties": {
                            "enchants": { "type": "array",
                                "items": { "$ref": "#/definitions/Enchants" }
                            },
                            "done": { "type": "boolean" }
                        },
						"additionalProperties": false,
                        "required": [
                            "enchants",
                            "done"
                        ]
                    }
                }
            },
            "required": [
                "items"
            ]
        },
        "ReforgeStep": { "type": "object",
            "properties": {
                "type": { "const": "reforge" },
                "items": { "type": "object",
                    "propertyNames": {
                        "$ref": "#/definitions/ItemIds"
                    },
					"additionalProperties": { "type": "object",
                        "properties": {
                            "reforges": { "type": "array",
                                "items": { "$ref": "#/definitions/Reforges" }
                            },
                            "done": { "type": "boolean" }
                        },
						"additionalProperties": false,
                        "required": [
                            "reforges",
                            "done"
                        ]
                    }
                }
            },
            "required": [
                "items"
            ]
        },
        "GuiItemStep": { "type": "object",
            "properties": {
                "type": { "const": "guiItem" },
                "guiName": { "type": "string" },
                "itemIndex": { "type": "integer" },
                "has": { "type": "string" },
                "doesntHave": { "type": "string" }
            },
            "required": [
                "guiName"
            ]
        },
        "ClickSlotStep": { "type": "object",
            "properties": {
                "type": { "const": "clickSlot" },
                "guiName": { "type": "string" },
                "slotIndex": { "type": "integer" },
                "has": { "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                },
                "doesntHave": { "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                },
                "playerInv": { "type": "boolean" }
            }
        },
        "SkillStep": { "type": "object",
            "properties": {
                "type": { "const": "skill" },
                "skill": { "$ref": "#/definitions/Skills" },
                "level": { "type": "number" }
            },
            "required": [
                "skill",
                "level"
            ]
        },
        "CollectionStep": { "type": "object",
            "properties": {
                "type": { "const": "collection" },
                "collection": { "$ref": "#/definitions/Collections" },
                "level": { "type": "integer" }
            },
            "required": [
                "collection",
                "level"
            ]
        },
        "StoreStep": { "type": "object",
            "properties": {
                "type": { "const": "store" },
                "items": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/ItemIds" }
                }
            },
            "required": [
                "items"
            ]
        },
        "RetrieveStep": { "type": "object",
            "properties": {
                "type": { "const": "retrieve" },
                "items": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/ItemIds" }
                }
            },
            "required": [
                "items"
            ]
        },
        "ExperienceStep": { "type": "object",
            "properties": {
                "type": { "const": "experience" },
                "level": { "type": "integer" }
            },
            "required": [
                "level"
            ]
        },
        "UpgradeMinionStep": { "type": "object",
            "properties": {
                "type": { "const": "upgradeMinion" },
                "minionId": { "$ref": "#/definitions/MinionIds" },
                "fromLevel": { "type": "integer" },
                "toLevel": { "type": "integer" }
            },
            "required": [
                "minionId",
                "fromLevel",
                "toLevel"
            ]
        },
		"MobTypesStep": { "type": "object",
            "properties": {
                "type": { "const": "mobTypes" },
                "mobTypes": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/MobTypes" }
                }
            },
            "required": [
                "mobTypes"
            ]
        },
		"MobTypes": {
            "enum": [
				"airborne",
				"animal",
				"aquatic",
				"arcane",
				"arthropod",
				"construct",
				"cubic",
				"elusive",
				"ender",
				"frozen",
				"glacial",
				"humanoid",
				"infernal",
				"magmatic",
				"mythological",
				"pest",
				"shielded",
				"skeletal",
				"spooky",
				"subterranean",
				"undead",
				"wither",
				"woodland"
			]
        },
        "MinionIds": {
            "type": "string"
        },
        "ItemIds": {
            "type": "string"
        },
        "Skills": {
            "type": "string"
        },
        "Collections": {
            "type": "string"
        },
        "Enchants": {
            "type": "string"
        },
        "Reforges": {
            "type": "string"
        },
        "Area": {
            "type": "string"
        },
        "SubArea": {
            "type": "string"
        }
    },
	"additionalProperties": false
}
